@page
@model TaskTracker.Api.Pages.Admin.TasksModel
@{
    ViewData["Title"] = "Task Admin";
}

<h1>Task Admin</h1>

<p>Read-only view of all tasks, rendered server-side with Razor Pages.</p>

<table border="1" cellpadding="8" cellspacing="0">
    <thead>
        <tr>
            <th>Title</th>
            <th>Description</th>
            <th>Due Date</th>
            <th>Completed</th>
            <th>Created</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var task in Model.Tasks)
        {
            <tr>
                <td>@task.Title</td>
                <td>@task.Description</td>
                <td>@(task.DueDate?.ToShortDateString() ?? "-")</td>
                <td>@(task.IsCompleted ? "Yes" : "No")</td>
                <td>@task.CreatedAt.ToShortDateString()</td>
            </tr>
        }
    </tbody>
</table>
